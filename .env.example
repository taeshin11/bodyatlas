# BodyAtlas environment template
# Copy to .env.local and fill in your values. .env.local is gitignored.
# All variables are optional — the app runs without them, just with reduced features.

# ── Deploy URL (R16 site-config) ───────────────────────────────────────────
# Used as base for canonical/OG/JSON-LD URLs across the app. Defaults to
# 'https://bodyatlas-ten.vercel.app' if unset.
NEXT_PUBLIC_SITE_URL=

# ── Feedback widget ────────────────────────────────────────────────────────
# Formspree form ID (e.g., xxxyyyyy). Without this, the feedback button
# falls back to mailto:taeshinkim11@gmail.com.
NEXT_PUBLIC_FORMSPREE_ID=

# ── Silent analytics ───────────────────────────────────────────────────────
# Google Sheets webhook URL. Without it, analytics events are dropped silently.
NEXT_PUBLIC_SHEETS_WEBHOOK_URL=

# ── Search portal verification (sitemap submission readiness) ──────────────
NEXT_PUBLIC_GOOGLE_VERIFICATION=
NEXT_PUBLIC_NAVER_VERIFICATION=
NEXT_PUBLIC_BING_VERIFICATION=
NEXT_PUBLIC_BAIDU_VERIFICATION=
NEXT_PUBLIC_YANDEX_VERIFICATION=

# ── Supabase (auth-gated atlases — currently no atlas requires auth) ───────
# isSupabaseConfigured() returns true only when both URL and key are set
# (R28 fix). Without these, AuthGate shows a placeholder.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Atlas pipeline auth (server-side scripts only — never NEXT_PUBLIC_*) ───
# TotalSegmentator academic license key, required by data_pipeline scripts
# that call brain_structures task. Frontend doesn't need this.
TOTALSEG_LICENSE=
