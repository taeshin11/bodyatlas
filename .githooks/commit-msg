#!/bin/sh
# Enforce FEATURES.md updates whenever user-facing feature code changes.
#
# Runs as commit-msg hook so the actual -m message is available via $1.
# Install (one-time, per clone): bash scripts/install-hooks.sh
# or                             scripts\install-hooks.bat
# (both just: git config core.hooksPath .githooks)
#
# Escape hatches:
#   - Include literal [skip-features-check] in commit message
#   - git commit --no-verify  (strongly discouraged)

MSG_FILE="$1"

# Check opt-out first (cheap)
if grep -qF '[skip-features-check]' "$MSG_FILE"; then
  echo "[commit-msg] [skip-features-check] detected; allowing"
  exit 0
fi

# Paths we consider "feature code"
FEATURE_PATTERNS='^(src/components/.+\.(tsx|ts)|src/app/.+/page\.tsx|src/app/layout\.tsx|src/lib/(auth-context|i18n|logger)\.(ts|tsx)|public/data/[^/]+/(info|structures)\.json|scripts/gen_.+\.py|scripts/auto_model_monitor\.py|package\.json)$'

staged="$(git diff --cached --name-only --diff-filter=ACMRD)"
feature_changes="$(printf '%s\n' "$staged" | grep -E "$FEATURE_PATTERNS" || true)"

# No feature-code changes? allow.
if [ -z "$feature_changes" ]; then
  exit 0
fi

# FEATURES.md also updated? allow.
if printf '%s\n' "$staged" | grep -qxE 'FEATURES\.md'; then
  exit 0
fi

# ── Block ────────────────────────────────────────────────────────────────
cat >&2 <<EOF

────────────────────────────────────────────────────────────────────────
❌ FEATURES.md 갱신 누락

다음 파일을 변경하면서 FEATURES.md를 같이 수정하지 않았습니다:
EOF
printf '  - %s\n' $feature_changes >&2
cat >&2 <<'EOF'

대응 방법 (택 1):
  1) FEATURES.md를 갱신한 뒤  git add FEATURES.md  하고 다시 커밋
  2) 기능 변화 없음이 확실하면 commit message에
     [skip-features-check] 를 포함
     (예: "chore: rename var [skip-features-check]")
  3) 비상시: git commit --no-verify (강력 비추천)

의무 규칙은 HANDOVER.md + FEATURES.md 상단에 문서화되어 있습니다.
────────────────────────────────────────────────────────────────────────
EOF

exit 1
